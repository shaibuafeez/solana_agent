# Groq AI (required for AI agent decisions)
# Note: env vars and config fields still say "GROK" for backward compatibility, but the backend is Groq (GroqCloud)
GROK_API_KEY=gsk_your_groq_api_key_here
GROK_MODEL=llama-3.3-70b-versatile

# Solana RPC (optional, defaults to public devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Jupiter API key (optional, for mainnet swaps — free tier uses public endpoint)
JUPITER_API_KEY=
